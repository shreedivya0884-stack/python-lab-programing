    "#finding highest among 3 numbers\n",
    "a=int(input(\"enter a:\"))\n",
    "b=int(input(\"enter b:\"))\n",
    "c=int(input(\"enter c:\"))\n",
    "if a>b and a>c:\n",
    "    print(\"the highest number is:\",a)\n",
    "elif b>a and b>c:\n",
    "    print(\"the highest number is:\",b)\n",
    "else:\n",
    "    print(\"the highest number is:\",c)"
